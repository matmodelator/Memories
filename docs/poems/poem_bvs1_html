  <!-- ОБЛАСТЬ ЧТЕНИЯ (скроллится) -->
<section class="reading-panel" aria-label="Текст стихотворения">

  <!-- Контейнер стиха -->

  <!-- ВАЖНО: pre сохраняет пробелы/табуляции/переносы -->
  <pre id="poem" class="poem-text"></pre>
  <!-- подпись внизу страницы -->
  
</section>

<div id="meta"></div>

  
  

    </pre>

  </section>

<script>
document.addEventListener("click", function(e) {
    const readingPanel = document.querySelector(".reading-panel");
    const nav = document.querySelector(".main-nav");

    if (!readingPanel.contains(e.target) && !nav.contains(e.target)) {
        window.location.href = "../index.html";
    }
});
</script>

  <!-- Утилита переадресации по пунктам Меню (для контента)-->
  <script src="../nav.js"></script>

  


 <!--  Контейнер для контента с переменными -->

<h1 id="title"></h1>
<p id="author"></p>
<p id="year"></p>
<div id="text"></div>
  



  <script>
document.addEventListener("DOMContentLoaded", function () {
  const poem = {
    author: "Игорь",
    year: "2024",
    title: "",
    text: `
Всё кончено. Твой статус: не в сети.
И время будто катится обратно.
Мне некуда и незачем идти,
А думать о других невероятно.

Я имя твоё пробую на вкус,
И твоя сладость мною так желанна.
Я фото твои знаю наизусть,
Ты смотришь с них, как несвятая Анна.

Всю боль твою хочу сейчас унять,
Во мне так много ласки и печали.
Понять тебя, а лучше бы обнять,
И так лежать касаючись плечами.  

Но зная, что с тобой мы заодно,
Не думать вновь, что я тебя теряю
А видеть только горы за окном,
Твой ник да имя снова повторяя.


09.11.24
`
  };

  // title = первая непустая строка, если пусто
  if (!poem.title.trim()) {
    poem.title = poem.text.split("\n").find(l => l.trim())?.trim() || "";
  }

  // 1) НАХОДИМ <pre id="poem">, или создаём
  let pre = document.getElementById("poem");
  if (!pre) {
    const panel = document.querySelector(".reading-panel");
    if (!panel) {
      alert("Не найден .reading-panel (проверь класс в HTML)");
      return;
    }
    pre = document.createElement("pre");
    pre.id = "poem";
    pre.className = "poem-text";
    panel.appendChild(pre);
  }

  // 2) ВСТАВЛЯЕМ ТЕКСТ (в <pre> это будет “без изменений”)
  pre.textContent = poem.text;

  // 3) НИЖНЯЯ ПОДПИСЬ (С автором и БЕЗ)
  const meta = document.getElementById("meta");
 // if (meta) meta.textContent = `${poem.author} — ${poem.title} — ${poem.year}`;}); 
if (meta) meta.textContent = `${poem.title} — ${poem.year}`;});
    
  // 4) Стили “поверх фона” + внизу
  meta.style.position = "fixed";
  meta.style.left = "0";
  meta.style.right = "0";
  meta.style.bottom = "10px";
  meta.style.textAlign = "center";
  meta.style.fontSize = "14px";
  meta.style.color = "brown";
  meta.style.opacity = "0.85";
  meta.style.zIndex = "9999";
  meta.style.pointerEvents = "none";
  meta.style.textShadow = "0 1px 2px rgba(0,0,0,0.7)";
 
    
</script>

</body>
</html>
